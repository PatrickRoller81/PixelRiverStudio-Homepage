<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Pixel River Studio</title>
  <meta name="description" content="{{ summary or 'Indie Game Studio. Wir bauen RiverTycoon.' }}">
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
  <header class="site-header">
    <a href="/" class="logo">Pixel River <span>Studio</span></a>
    <nav>
      <a href="/">Home</a>
      <a href="/devlog/">DevLog</a>
      <a href="/leistungen/">Leistungen</a>
      <a href="/impressum/">Impressum</a>
    </nav>
  </header>
  <main>{{ content | safe }}</main>

  {% if comments == true %}
  <section class="comments">
    <h2>Kommentare</h2>
    <script src="https://giscus.app/client.js"
      data-repo="PatrickRoller81/PixelRiverStudio-Homepage"
      data-repo-id="R_kgDOR4XlDQ"
      data-category="DevLog Comments"
      data-category-id="DIC_kwDOR4XlDc4C6hfr"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="dark"
      data-lang="de"
      crossorigin="anonymous"
      async>
    </script>
  </section>
  {% endif %}
  <footer>
    <p>&copy; 2026 Pixel River Studio &middot; <a href="https://github.com/PatrickRoller81" target="_blank">GitHub</a> &middot; <a href="/impressum/">Impressum</a></p>
  </footer>
</body>
</html>
